# EduWeb Booking — variables d'environnement (exemple, sans secret réel).
# À définir dans Vercel (Project → Settings → Environment Variables) et en local (.env).

# PostgreSQL (Neon). DATABASE_URL = connexion « pooled » (pgbouncer) pour l'app ;
# DIRECT_URL = connexion directe pour les migrations / prisma db push.
# connect_timeout/pool_timeout élevés sur l'URL pooled : laissent Neon sortir de veille (offre gratuite).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=30&pool_timeout=30"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret de signature des sessions JWT (chaîne aléatoire ≥ 32 caractères).
# Générer : node -e "console.log(require('crypto').randomBytes(36).toString('base64url'))"
AUTH_SECRET="change-me-strong-random-secret"

# URL publique de l'application. EN PRODUCTION : https://booking.eduweb.ci
# (sert à construire le lien de confirmation d'e-mail envoyé aux nouveaux comptes).
APP_URL="http://localhost:3000"

# Resend (transport e-mail principal — confirmation de compte, notifications).
# Domaine d'envoi vérifié : booking.eduweb.ci. Créer une clé API sur resend.com.
RESEND_API_KEY=""
# Expéditeur (doit appartenir au domaine vérifié). Défaut : EduWeb Booking <no-reply@booking.eduweb.ci>
RESEND_FROM="EduWeb Booking <no-reply@booking.eduweb.ci>"

# SMTP (repli si Resend non configuré). Laisser vide pour journaliser les e-mails en console (dev).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
# Le nom d'expéditeur affiché est toujours « EduWeb Booking » (forcé dans le code) ;
# seule l'adresse de SMTP_FROM est utilisée (« adresse » ou « Nom <adresse> »).
SMTP_FROM="EduWeb Booking <no-reply@eduweb.ci>"

# WhatsApp Business API (V2)
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
